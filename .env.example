# TamirBul — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyala: cp .env.example .env.local
# Gerçek değerleri doldur — bu dosyayı asla commit etme

# Supabase (dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJh...

# Clerk (dashboard → API Keys)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Google Maps (Google Cloud Console → APIs & Services)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# EAS (eas.json içinde tanımlı — genellikle direkt EAS dashboard'dan yönetilir)
# EXPO_PUBLIC_EAS_PROJECT_ID=...
